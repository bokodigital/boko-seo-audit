# Optional: password-gate the dashboard. Leave blank for open access.
APP_PASSWORD=

# ---- Google Analytics 4 + Search Console (service account) ----
# From your Google Cloud service account JSON key.
GOOGLE_CLIENT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# The private_key value from the JSON, with newlines escaped as \n (keep the quotes in Vercel).
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---- Ahrefs (optional) ----
# Enables the free Domain Rating badge on each audit. Your Ahrefs API key.
# Only the free public Domain Rating endpoint is used (no API units consumed).
# If the key is missing or your plan rejects it, the audit still works; the DR badge is simply hidden.
AHREFS_API_KEY=
